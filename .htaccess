RewriteEngine On

# API -> PHP front controller (без /public/ в URL)
# RewriteBase не задаём: работает и на поддомене (jattau.krg-ktsk.kz), и в /jattau/ на MAMP
RewriteRule ^api/ public/index.php [L,QSA]

DirectoryIndex index.html
Options -Indexes

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<Files ".env">
    Require all denied
</Files>
